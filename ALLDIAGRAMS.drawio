        <UserObject label="https://chatgpt.com/backend-api/estuary/content?id=file_000000002c787208b8a9d4188957a801&amp;ts=493229&amp;p=fs&amp;cid=1&amp;sig=b6f047b3db7514de133710bb5e69ac3ffcde36e370df7ce89274f29437c680fc&amp;v=0" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle FarmEase ER Diagram\n\nentity User {\n  +Id : string &lt;&lt;PK&gt;&gt;\n  --\n  FullName : string\n  Email : string &lt;&lt;UNIQUE&gt;&gt;\n  Phone : string\n  PasswordHash : string\n  Role : string\n}\n\nentity AgriItem {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  Name : string\n  Category : string\n  Price : decimal\n  Quantity : int\n  PostedBy : string &lt;&lt;FK&gt;&gt;\n}\n\nentity Machinery {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  Name : string\n  Category : string\n  Price : decimal\n  Quantity : int\n}\n\nentity CartItem {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  UserId : string &lt;&lt;FK&gt;&gt;\n  ProductId : long\n  Quantity : int\n}\n\nentity WishlistItem {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  UserId : string &lt;&lt;FK&gt;&gt;\n  ProductId : long\n}\n\nentity Order {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  UserId : string &lt;&lt;FK&gt;&gt;\n  TotalAmount : decimal\n  OrderDate : datetime\n  Status : string\n}\n\nentity OrderItem {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  OrderId : long &lt;&lt;FK&gt;&gt;\n  ProductId : long\n  Quantity : int\n  Price : decimal\n}\n\nentity ChatMessage {\n  +Id : long &lt;&lt;PK&gt;&gt;\n  --\n  SenderEmail : string\n  ReceiverEmail : string\n  Content : string\n  Timestamp : datetime\n}\n\n&#39; ================= RELATIONSHIPS =================\n\nUser ||--o{ Order : places\nUser ||--o{ CartItem : has\nUser ||--o{ WishlistItem : saves\nUser ||--o{ AgriItem : posts\n\nOrder ||--o{ OrderItem : contains\n\nUser ||--o{ ChatMessage : sends\nUser ||--o{ ChatMessage : receives\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="UpLjB_ycdYL_HFfkXJLp-1">
