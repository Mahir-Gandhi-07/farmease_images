        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nactor User\nactor Farmer\nactor Admin\n\nrectangle \&quot;Process 1: Authentication\&quot; {\n  (Login/Register)\n}\n\nrectangle \&quot;Process 2: Product Management\&quot; {\n  (Manage Products)\n}\n\nrectangle \&quot;Process 3: Order Management\&quot; {\n  (Manage Orders)\n}\n\nrectangle \&quot;Process 4: Cart &amp; Wishlist\&quot; {\n  (Cart/Wishlist)\n}\n\nrectangle \&quot;Process 5: Chat System\&quot; {\n  (Chat)\n}\n\ndatabase DB\n\n&#39; ===== User Flow =====\nUser --&gt; (Login/Register)\n(Login/Register) --&gt; DB\n\nUser --&gt; (Cart/Wishlist)\n(Cart/Wishlist) --&gt; DB\n\nUser --&gt; (Manage Orders)\n(Manage Orders) --&gt; DB\n\nUser --&gt; (Chat)\n(Chat) --&gt; DB\n\n&#39; ===== Farmer Flow =====\nFarmer --&gt; (Manage Products)\n(Manage Products) --&gt; DB\n\nFarmer --&gt; (Manage Orders)\n\n&#39; ===== Admin Flow =====\nAdmin --&gt; (Manage Products)\nAdmin --&gt; (Manage Orders)\nAdmin --&gt; (Login/Register)\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2tKGS8DB4DH6Jdg7B7IB-18">
