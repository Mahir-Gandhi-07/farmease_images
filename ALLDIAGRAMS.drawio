          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n\nclass User {\n  +Id : string\n  +Name : string\n  +Email : string\n  +Password : string\n  +Role : string\n}\n\nclass AgriItem {\n  +Id : long\n  +Name : string\n  +Category : string\n  +Price : decimal\n  +Quantity : int\n}\n\nclass Machinery {\n  +Id : long\n  +Name : string\n  +Category : string\n  +Price : decimal\n  +Quantity : int\n}\n\nclass CartItem {\n  +Id : long\n  +UserId : string\n  +ProductId : long\n  +Quantity : int\n}\n\nclass WishlistItem {\n  +Id : long\n  +UserId : string\n  +ProductId : long\n}\n\nclass Order {\n  +Id : long\n  +UserId : string\n  +TotalAmount : decimal\n  +Status : string\n}\n\nclass OrderItem {\n  +Id : long\n  +OrderId : long\n  +ProductId : long\n  +Quantity : int\n  +Price : decimal\n}\n\nclass ChatMessage {\n  +Id : long\n  +SenderEmail : string\n  +ReceiverEmail : string\n  +Message : string\n}\n\n&#39; ===== RELATIONSHIPS =====\n\nUser \&quot;1\&quot; -- \&quot;many\&quot; Order\nUser \&quot;1\&quot; -- \&quot;many\&quot; CartItem\nUser \&quot;1\&quot; -- \&quot;many\&quot; WishlistItem\n\nOrder \&quot;1\&quot; -- \&quot;many\&quot; OrderItem\n\nUser \&quot;1\&quot; -- \&quot;many\&quot; ChatMessage : sends\nUser \&quot;1\&quot; -- \&quot;many\&quot; ChatMessage : receives\n\nUser \&quot;1\&quot; -- \&quot;many\&quot; AgriItem : posts\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2tKGS8DB4DH6Jdg7B7IB-19">
